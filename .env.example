# Copy this file to .env and fill in your real keys.
# Example in PowerShell:
# Copy-Item .env.example .env

GEMINI_API_KEY=paste_your_gemini_key_here

# OpenRouter (OpenAI-compatible)
OPENROUTER_API_KEY=paste_your_openrouter_key_here
# Optional: identifies your app for OpenRouter ranking
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=misinformation-llm-simulation

# DeepSeek (official API, OpenAI-compatible)
DEEPSEEK_API_KEY=paste_your_deepseek_key_here

# Local OpenAI-compatible endpoint (optional)
LOCAL_OPENAI_API_KEY=ollama
LOCAL_OPENAI_BASE_URL=http://127.0.0.1:11434/v1

# NewsData.io
NEWSDATA_API_KEY=paste_your_newsdata_key_here
