# Copie este arquivo para .env e preencha com sua chave real.
# Exemplo no PowerShell:
# Copy-Item .env.example .env

GEMINI_API_KEY=cole_sua_chave_do_gemini_aqui

# OpenRouter (OpenAI-compatible)
OPENROUTER_API_KEY=cole_sua_chave_do_openrouter_aqui
# Opcional: identifica seu app para ranking no OpenRouter
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=misinformation-llm-simulation

# DeepSeek (API oficial, OpenAI-compatible)
DEEPSEEK_API_KEY=cole_sua_chave_do_deepseek_aqui

# NewsData.io
NEWSDATA_API_KEY=cole_sua_chave_do_newsdata_aqui
